# See wiki/caddy.md

:80 {
    @public-utils-denied {
        path /utils/pgadmin*
        not remote_ip private_ranges
    }
    @unknown-utils {
        path /utils/*
        not path /utils/pgadmin*
    }

    # Keep admin and observability UIs reachable only from localhost/private networks.
    respond @public-utils-denied "Forbidden" 403
    # Deny any other /utils routes so they don't fall through to the SPA.
    respond @unknown-utils "Not Found" 404

    handle /items* {
        reverse_proxy http://backend:8000
    }
    handle /flashcards* {
        reverse_proxy http://backend:8000
    }
    handle /auth* {
        reverse_proxy http://backend:8000
    }
    handle /learners* {
        reverse_proxy http://backend:8000
    }
    handle /interactions* {
        reverse_proxy http://backend:8000
    }
    handle /pipeline* {
        reverse_proxy http://backend:8000
    }
    handle /analytics* {
        reverse_proxy http://backend:8000
    }
    handle /utils/pgadmin* {
        reverse_proxy http://pgadmin:80
    }
    handle /docs* {
        reverse_proxy http://backend:8000
    }
    handle /openapi.json {
        reverse_proxy http://backend:8000
    }
    handle_path /flutter* {
        root * /srv/flutter
        try_files {path} /index.html
        file_server
    }
    handle {
        root * /srv/react
        try_files {path} /index.html
        file_server
    }
}
